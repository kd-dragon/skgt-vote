# 서버 포트 (기본 3000)
PORT=3000

# 관리자 접근용 비밀 경로 slug. 이 값을 아는 사람만 /admin/<slug> 로 접근 가능.
# 비밀 URL 이자 백엔드 관리자 인증 토큰으로 함께 사용됨.
# 미설정 시 개발용 기본값 "dev" 사용 (→ /admin/dev). 운영 배포 시 반드시 설정할 것!
ADMIN_SLUG=

# 채팅 보관 시간(분). 이 시간이 지난 오래된 채팅은 자동 정리(메모리 보호).
# 미설정 시 기본 60분. (개수 상한 200개는 코드에 하드코딩된 별도 안전장치)
CHAT_TTL_MIN=60
