# 프로덕션 환경변수 예시 — 서버에서 .env 로 복사 후 값 채우기
# (systemd 유닛에도 동일 값을 넣으므로, 관리 방식은 둘 중 하나로 통일하는 것을 권장)

# 앱이 리스닝할 포트 (Nginx 가 이 포트로 프록시)
PORT=3000

# 관리자 비밀 URL slug 겸 인증 토큰. 추측 불가능한 긴 값으로!
# 예) openssl rand -hex 12  로 생성
ADMIN_SLUG=바꾸세요_긴_랜덤_문자열

# 채팅 보관 시간(분). 초과한 오래된 채팅 자동 정리(메모리 보호). 기본 60분.
CHAT_TTL_MIN=60
